<div {{ attributes }}>
    <div class="bg-white rounded-3xl border border-slate-200 shadow-sm flex flex-col min-h-[600px] overflow-hidden">
        <div class="flex flex-col md:flex-row h-full">
            <!-- Sidebar Ustawień -->
            <div class="w-full md:w-72 bg-slate-50 border-r border-slate-200 flex flex-col p-4 gap-2 shrink-0">
                <div class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 px-4 mt-2">Zarządzanie Zespołem</div>
                <button 
                    data-action="live#update" 
                    data-model="settingsTab" 
                    data-value="roles"
                    class="text-left px-4 py-3 rounded-xl text-sm font-bold transition {{ settingsTab == 'roles' ? 'bg-white shadow-sm text-indigo-600 border border-slate-200' : 'text-slate-600 hover:bg-slate-200/50' }}"
                >
                    Użytkownicy i Uprawnienia
                </button>
                
                <div class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 px-4 mt-4">System i Księgowość</div>
                <button 
                    data-action="live#update" 
                    data-model="settingsTab" 
                    data-value="billing"
                    class="text-left px-4 py-3 rounded-xl text-sm font-bold transition {{ settingsTab == 'billing' ? 'bg-white shadow-sm text-indigo-600 border border-slate-200' : 'text-slate-600 hover:bg-slate-200/50' }}"
                >
                    Odbiorcy raportów fin.
                </button>
                <button 
                    data-action="live#update" 
                    data-model="settingsTab" 
                    data-value="seo"
                    class="text-left px-4 py-3 rounded-xl text-sm font-bold transition {{ settingsTab == 'seo' ? 'bg-white shadow-sm text-indigo-600 border border-slate-200' : 'text-slate-600 hover:bg-slate-200/50' }}"
                >
                    SEO i robots.txt
                </button>
            </div>

            <!-- Kontent Ustawień -->
            <div class="flex-1 p-8 overflow-y-auto">
                
                {% if settingsTab == 'roles' %}
                    <div class="space-y-6 animate-in fade-in">
                        <div>
                            <h2 class="text-xl font-black text-slate-800">Administratorzy i Prowadzący</h2>
                            <p class="text-sm text-slate-500 mt-1">Nadawaj uprawnienia użytkownikom. Prowadzący mają dostęp tylko do list obecności na swoich zajęciach, Administratorzy mają pełen dostęp.</p>
                        </div>
                        
                        <!-- Grupa Administratorów -->
                        <div class="border border-slate-200 rounded-2xl overflow-hidden">
                            <div class="bg-slate-50 p-4 border-b border-slate-200 font-bold text-slate-800 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                                Administratorzy Systemu
                            </div>
                            
                            <div class="p-4">
                                <div class="flex gap-2 mb-4">
                                    <select 
                                        data-model="newAdminUserId"
                                        class="flex-1 p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
                                    >
                                        <option value="">Wybierz użytkownika...</option>
                                        {% for user in getUsers() %}
                                            {% if not hasRole(user, 'ROLE_ADMIN') %}
                                                <option value="{{ user.id }}">{{ user.name }} ({{ user.email }})</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                    <button 
                                        data-action="live#action" data-live-action-param="addAdminUser"
                                        class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-bold hover:bg-indigo-700 transition"
                                    >
                                        Dodaj
                                    </button>
                                </div>
                                
                                {% for user in getAdminUsers() %}
                                    <div class="flex justify-between items-center hover:bg-slate-50 p-2 rounded-lg">
                                        <div>
                                            <div class="font-bold text-sm">{{ user.name }}</div>
                                            <div class="text-xs text-slate-500">{{ user.email }}</div>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <span class="bg-slate-200 text-slate-600 text-[10px] font-bold px-2 py-1 rounded">Admin</span>
                                            <button 
                                                data-action="live#action" data-live-action-param="removeAdminUser" data-live-action-param-userId="{{ user.id }}"
                                                class="text-xs font-bold text-red-600 hover:underline"
                                            >
                                                Odbierz dostęp
                                            </button>
                                        </div>
                                    </div>
                                {% else %}
                                    <div class="text-sm text-slate-500 text-center py-4">Brak administratorów</div>
                                {% endfor %}
                            </div>
                        </div>

                        <!-- Grupa Prowadzących -->
                        <div class="border border-slate-200 rounded-2xl overflow-hidden mt-6">
                            <div class="bg-slate-50 p-4 border-b border-slate-200 font-bold text-slate-800 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                                Prowadzący Zajęcia
                            </div>
                            <div class="p-4">
                                {% for user in getInstructorUsers() %}
                                    <div class="flex justify-between items-center hover:bg-slate-50 p-2 rounded-lg">
                                        <div>
                                            <div class="font-bold text-sm">{{ user.name }}</div>
                                            <div class="text-xs text-slate-500">{{ user.email }}</div>
                                        </div>
                                        <span class="bg-indigo-100 text-indigo-700 text-[10px] font-bold px-2 py-1 rounded">Prowadzący</span>
                                    </div>
                                {% else %}
                                    <div class="text-sm text-slate-500 text-center py-4">Brak prowadzących</div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}

                {% if settingsTab == 'billing' %}
                    <div class="space-y-6 animate-in fade-in">
                        <div>
                            <h2 class="text-xl font-black text-slate-800">Kontakty Finansowe i Fakturowanie</h2>
                            <p class="text-sm text-slate-500 mt-1">Kto powinien otrzymywać na email automatyczne zestawienia prowizji (2%) oraz raporty niezidentyfikowanych przelewów?</p>
                        </div>
                        
                        <div class="bg-slate-50 p-5 rounded-2xl border border-slate-200 max-w-lg space-y-4">
                            <div class="flex gap-2 mb-4">
                                <select 
                                    data-model="newFinanceContactUserId"
                                    class="flex-1 p-2 bg-white border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
                                >
                                    <option value="">Wybierz użytkownika...</option>
                                    {% for user in getUsers() %}
                                        {% if user.id not in financeContactUserIds %}
                                            <option value="{{ user.id }}">{{ user.name }} ({{ user.email }})</option>
                                        {% endif %}
                                    {% endfor %}
                                </select>
                                <button 
                                    data-action="live#action" data-live-action-param="addFinanceContact"
                                    class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-bold hover:bg-indigo-700 transition"
                                >
                                    Dodaj
                                </button>
                            </div>
                            
                            {% for user in getFinanceContactUsers() %}
                                <div class="flex items-center gap-3 bg-white p-3 rounded-xl border border-slate-200 shadow-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                                    <input type="text" value="{{ user.email }}" class="flex-1 bg-transparent text-sm font-bold text-slate-800 outline-none" readonly />
                                    <button 
                                        data-action="live#action" data-live-action-param="removeFinanceContact" data-live-action-param-userId="{{ user.id }}"
                                        class="text-red-500 hover:bg-red-50 p-1.5 rounded-lg transition"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            {% else %}
                                <div class="text-sm text-slate-500 text-center py-4">Brak kontaktów finansowych</div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {% if settingsTab == 'seo' %}
                    <div class="space-y-6 animate-in fade-in">
                        <div>
                            <h2 class="text-xl font-black text-slate-800">SEO & Pliki Systemowe</h2>
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-700 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                                robots.txt
                            </label>
                            <textarea 
                                data-model="robotsTxtContent"
                                rows="4" 
                                class="w-full bg-slate-900 text-green-400 font-mono text-sm p-4 rounded-xl outline-none"
                            >{{ robotsTxtContent }}</textarea>
                        </div>
                        <button 
                            data-action="live#action" data-live-action-param="saveRobotsTxt"
                            class="px-6 py-2.5 bg-indigo-600 text-white rounded-xl text-sm font-bold hover:bg-indigo-700 transition"
                        >
                            Zapisz robots.txt
                        </button>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
