<div {{ attributes }} data-controller="live">
    {# Redesigned high-fidelity dashboard blocks #}
    {% if activeTab == 'dashboard' %}
        {# Platform Billing Component #}
        <div class="mb-6 grid grid-cols-1 md:grid-cols-4 gap-4">
            {{ component('PlatformBillingComponent') }}
        </div>
    {% endif %}

    <div class="space-y-6">
        {% if activeTab == 'dashboard' %}
            {# KPI Statistics Row #}
            {% set kpi = this.getKpiStats() %}
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                {# KPI 1: Reservations #}
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col justify-between h-40">
                    <h4 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Rezerwacje (Czerwiec)</h4>
                    <div class="text-4xl font-black text-slate-800 tracking-tight mb-2">{{ kpi.bookingsCount }}</div>
                    <div class="text-xs text-slate-400 font-medium">Zarejestrowane rezerwacje</div>
                </div>
                
                {# KPI 2: Revenue #}
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col justify-between h-40">
                    <h4 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Przychód (Czerwiec)</h4>
                    <div class="text-4xl font-black text-slate-800 tracking-tight mb-2">{{ kpi.revenue }}</div>
                    <div class="text-xs text-slate-400 font-medium">Suma opłaconych rezerwacji</div>
                </div>
                
                {# KPI 3: System Fee - Now handled by PlatformBillingComponent above #}
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col justify-between h-40">
                    <h4 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Średnia zajętość</h4>
                    <div class="text-4xl font-black text-slate-800 tracking-tight mb-2">{{ kpi.occupancyRate }}</div>
                    <div class="text-xs text-slate-400 font-medium">Średnia zajętość zajęć</div>
                </div>
            </div>

            {# Mockup Columns Grid #}
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                {# Column 1: Upcoming Calendar Days #}
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col">
                    <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-50">
                        <h3 class="flex items-center gap-3 text-base font-black text-slate-800">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>
                            <span>Kalendarz - Najbliższe dni</span>
                        </h3>
                        <a href="{{ path('app_admin_lessons') }}" class="text-xs font-bold text-indigo-600 hover:text-indigo-800 hover:underline transition">
                            Zarządzaj grafikiem
                        </a>
                    </div>
                    
                    {# Timeline events list #}
                    <div class="space-y-6 relative pl-4 before:absolute before:left-[21px] before:top-4 before:bottom-4 before:w-0.5 before:bg-slate-100">
                        {# Timeline Date Node #}
                        <div class="space-y-3 relative">
                            <div class="absolute left-[-2px] top-1.5 w-2 h-2 rounded-full bg-indigo-600 z-10"></div>
                            <span class="text-xs font-bold text-slate-400 pl-4">Dziś (15 Czerwca)</span>
                            
                            {% for item in this.getCalendarLessons() %}
                                <div class="p-4 border border-slate-100 rounded-2xl bg-slate-50/50 flex flex-col sm:flex-row sm:items-center justify-between gap-4 pl-4 ml-4">
                                    <div class="flex items-start gap-4">
                                        {# Time slot #}
                                        <div class="h-11 w-20 flex items-center justify-center bg-white rounded-xl border border-slate-100 text-xs font-bold text-slate-600 shadow-sm shrink-0">
                                            {{ item.time }}
                                        </div>
                                        <div>
                                            <h4 class="text-sm font-bold text-slate-800">{{ item.title }}</h4>
                                            <p class="text-xs text-slate-400 font-medium mt-1">Prowadzi: {{ item.instructor }} • {{ item.age }}</p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-3 self-end sm:self-auto shrink-0">
                                        <span class="text-xs font-bold text-emerald-600 bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-xl">
                                            Miejsce: {{ item.capacity }}
                                        </span>
                                        <span class="text-[10px] font-bold text-emerald-700 bg-emerald-100/40 px-2 py-1 rounded-lg">
                                            {{ item.status }}
                                        </span>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# Column 2: Recent Activity Logs #}
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col">
                    <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-50">
                        <h3 class="flex items-center gap-3 text-base font-black text-slate-800">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M16 3h5v5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 21H3v-5"/></svg>
                            <span>Ostatnie zmiany klientów</span>
                        </h3>
                        <button type="button" class="text-slate-400 hover:text-slate-600 transition">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-refresh-cw"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
                        </button>
                    </div>
                    
                    {# Activity feed rows #}
                    <div class="space-y-4">
                        {% for log in this.getActivityLog() %}
                            <div class="p-5 border border-slate-100 rounded-3xl bg-white shadow-sm flex flex-col gap-3 relative overflow-hidden">
                                {# Colored top border tag #}
                                <div class="absolute top-0 right-0 left-0 h-1 {{ log.type == 'cancelled' ? 'bg-amber-400' : 'bg-blue-400' }}"></div>
                                
                                <div class="flex items-start justify-between">
                                    <div>
                                        <span class="inline-flex items-center rounded-lg px-2.5 py-1 text-[10px] font-bold leading-none tracking-tight {{ log.type == 'cancelled' ? 'bg-amber-50 text-amber-700 border border-amber-100' : 'bg-blue-50 text-blue-700 border border-blue-100' }}">
                                            {{ log.badge }}
                                        </span>
                                        <h4 class="font-bold text-slate-800 text-sm mt-2">{{ log.name }}</h4>
                                        <p class="text-xs text-slate-400 font-medium mt-1">{{ log.lesson }}</p>
                                    </div>
                                </div>
                                {% if log.notes %}
                                    <div class="text-[10px] text-slate-400 font-medium bg-slate-50 p-3 rounded-xl border border-slate-100/50 mt-1 leading-relaxed">
                                        {{ log.notes }}
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% elseif activeTab == 'bookings' %}
            {{ component('AdminBookingsComponent') }}
        {% elseif activeTab == 'users' %}
            {{ component('UsersComponent') }}
        {% elseif activeTab == 'transfers' %}
            {{ component('PaymentsListComponent') }}
            {{ component('PaymentComponent') }}
        {% elseif activeTab == 'messages' %}
            {{ component('UserMessagesComponent') }}
        {% elseif activeTab == 'lessons' %}
            {{ component('AdminLessonsComponent') }}
        {% elseif activeTab == 'schedule' %}
            {{ component('AdminScheduleComponent') }}
        {% elseif activeTab == 'settings' %}
            {# Rebuild settings container with slate card layout #}
            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
                <div class="flex border-b border-slate-200 bg-slate-50">
                    <button 
                        data-action="live#update" 
                        data-model="settingsTab" 
                        data-value="general"
                        class="px-6 py-4 font-bold text-sm transition-all border-b-2 {{ settingsTab == 'general' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-800' }}"
                    >
                        {{ 'admin.settings.tabs.general'|trans }}
                    </button>
                    <button 
                        data-action="live#update" 
                        data-model="settingsTab" 
                        data-value="team"
                        class="px-6 py-4 font-bold text-sm transition-all border-b-2 {{ settingsTab == 'team' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-800' }}"
                    >
                        {{ 'admin.settings.tabs.team'|trans }}
                    </button>
                    <button 
                        data-action="live#update" 
                        data-model="settingsTab" 
                        data-value="billing"
                        class="px-6 py-4 font-bold text-sm transition-all border-b-2 {{ settingsTab == 'billing' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-800' }}"
                    >
                        {{ 'admin.settings.tabs.billing'|trans }}
                    </button>
                    <button 
                        data-action="live#update" 
                        data-model="settingsTab" 
                        data-value="seo"
                        class="px-6 py-4 font-bold text-sm transition-all border-b-2 {{ settingsTab == 'seo' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-800' }}"
                    >
                        {{ 'admin.settings.tabs.seo'|trans }}
                    </button>
                </div>
                <div class="p-6">
                    {% if settingsTab == 'general' %}
                        <h3 class="text-lg font-black text-slate-800 mb-4">{{ 'admin.settings.general.title'|trans }}</h3>
                    {% elseif settingsTab == 'team' %}
                        <h3 class="text-lg font-black text-slate-800 mb-4">{{ 'admin.settings.team.title'|trans }}</h3>
                    {% elseif settingsTab == 'billing' %}
                        <h3 class="text-lg font-black text-slate-800 mb-4">{{ 'admin.settings.billing.title'|trans }}</h3>
                    {% elseif settingsTab == 'seo' %}
                        <h3 class="text-lg font-black text-slate-800 mb-4">{{ 'admin.settings.seo.title'|trans }}</h3>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <p class="text-slate-400 italic font-medium">{{ 'admin.tabs.coming_soon'|trans({tab: activeTab}) }}</p>
            </div>
        {% endif %}
    </div>
</div>
