{% if isModalOpen %}
<div {{ attributes }}>
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-4xl rounded-2xl shadow-2xl flex flex-col max-h-[90vh] animate-in fade-in zoom-in-95 duration-200">
            
            <!-- Header -->
            <div class="flex justify-between items-center p-6 border-b border-slate-100">
                <div>
                    <h2 class="text-xl font-black text-slate-800">Kreator Warsztatów</h2>
                    <p class="text-sm text-slate-500">Dodaj lub edytuj wydarzenie i zasady sprzedaży</p>
                </div>
                <button 
                    data-action="live#action" data-live-action-param="closeModal"
                    class="p-2 text-slate-400 hover:bg-slate-100 rounded-full transition"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>

            <!-- Tabs -->
            <div class="flex px-6 border-b border-slate-200 bg-slate-50">
                <button 
                    data-action="live#update" 
                    data-model="activeTab" 
                    data-value="general"
                    class="px-4 py-3 text-sm font-bold border-b-2 transition {{ activeTab == 'general' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-700' }}"
                >
                    Podstawowe
                </button>
                <button 
                    data-action="live#update" 
                    data-model="activeTab" 
                    data-value="schedule"
                    class="px-4 py-3 text-sm font-bold border-b-2 transition {{ activeTab == 'schedule' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-700' }}"
                >
                    Harmonogram i Cykliczność
                </button>
                <button 
                    data-action="live#update" 
                    data-model="activeTab" 
                    data-value="tickets"
                    class="px-4 py-3 text-sm font-bold border-b-2 transition {{ activeTab == 'tickets' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-700' }}"
                >
                    Bilety, Karnety i Zasady
                </button>
                <button 
                    data-action="live#update" 
                    data-model="activeTab" 
                    data-value="instructors"
                    class="px-4 py-3 text-sm font-bold border-b-2 transition {{ activeTab == 'instructors' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-700' }}"
                >
                    Prowadzący
                </button>
            </div>

            <!-- Form Body - Scrollable -->
            <div class="p-6 overflow-y-auto custom-scrollbar flex-1">
                
                <!-- TAB: GENERAL -->
                {% if activeTab == 'general' %}
                    <div class="space-y-5">
                        <div class="grid grid-cols-2 gap-5">
                            <div class="space-y-1.5 col-span-2 md:col-span-1">
                                <label class="text-sm font-bold text-slate-700">Nazwa warsztatów *</label>
                                <input 
                                    type="text" 
                                    data-model="title"
                                    placeholder="np. Błotna Kuchnia" 
                                    class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" 
                                />
                            </div>
                            <div class="space-y-1.5 col-span-2 md:col-span-1">
                                <label class="text-sm font-bold text-slate-700">Kategoria *</label>
                                <select 
                                    data-model="category"
                                    class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none"
                                >
                                    <option value="">Wybierz kategorię...</option>
                                    {% for cat in getCategories() %}
                                        <option value="{{ cat }}" {{ category == cat ? 'selected' : '' }}>{{ cat }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-5">
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-slate-700">Przedział wiekowy</label>
                                <div class="flex items-center gap-2">
                                    <input 
                                        type="number" 
                                        data-model="ageMin"
                                        placeholder="0" 
                                        class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                    />
                                    <span class="text-slate-400">-</span>
                                    <input 
                                        type="number" 
                                        data-model="ageMax"
                                        placeholder="10" 
                                        class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                    />
                                    <span class="text-sm text-slate-500">lat</span>
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-slate-700">Limit miejsc (pojemność sali)</label>
                                <input 
                                    type="number" 
                                    data-model="capacity"
                                    value="{{ capacity|default(10) }}" 
                                    class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                />
                            </div>
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-slate-700">Opis (widoczny dla klientów) *</label>
                            <textarea 
                                data-model="description"
                                rows="4" 
                                class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                placeholder="Opisz co będzie się dziać..."
                            >{{ description|default('') }}</textarea>
                        </div>

                        <div class="grid grid-cols-2 gap-5">
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-slate-700">Krótki opis (lead)</label>
                                <input 
                                    type="text" 
                                    data-model="lead"
                                    placeholder="Krótki opis w jednym zdaniu" 
                                    class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                />
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-slate-700">Motyw wizualny</label>
                                <input 
                                    type="text" 
                                    data-model="visualTheme"
                                    placeholder="np. orange-100" 
                                    class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                />
                            </div>
                        </div>
                    </div>
                {% endif %}

                <!-- TAB: SCHEDULE -->
                {% if activeTab == 'schedule' %}
                    <div class="space-y-6">
                        <div class="p-4 rounded-xl border-2 border-indigo-100 bg-indigo-50/50 flex gap-4">
                            <div class="flex-1">
                                <label class="flex items-center gap-2 text-sm font-bold text-indigo-900 mb-1">
                                    <input 
                                        type="radio" 
                                        name="scheduletype" 
                                        data-model="scheduleType"
                                        value="single"
                                        class="w-4 h-4 text-indigo-600" 
                                    /> Wydarzenie jednorazowe
                                </label>
                                <p class="text-xs text-indigo-700 ml-6">Klasyczne zajęcia w konkretnym dniu.</p>
                            </div>
                            <div class="flex-1">
                                <label class="flex items-center gap-2 text-sm font-bold text-indigo-900 mb-1">
                                    <input 
                                        type="radio" 
                                        name="scheduletype" 
                                        data-model="scheduleType"
                                        value="recurring"
                                        class="w-4 h-4 text-indigo-600" 
                                        checked
                                    /> Cykliczne (Powtarzalne)
                                </label>
                                <p class="text-xs text-indigo-700 ml-6">Tworzy serię wydarzeń np. co tydzień.</p>
                            </div>
                        </div>

                        <div class="space-y-4 border border-slate-200 p-5 rounded-xl">
                            <h3 class="font-bold text-slate-800 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
                                Konfiguracja Cyklu
                            </h3>
                            
                            <div class="grid grid-cols-2 gap-5">
                                <div class="space-y-1.5">
                                    <label class="text-sm font-bold text-slate-700">Dzień tygodnia</label>
                                    <select 
                                        data-model="dayOfWeek"
                                        class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none"
                                    >
                                        <option value="">Wybierz dzień...</option>
                                        {% for dayKey, dayLabel in getDaysOfWeek() %}
                                            <option value="{{ dayKey }}" {{ dayOfWeek == dayKey ? 'selected' : '' }}>{{ dayLabel }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="space-y-1.5">
                                    <label class="text-sm font-bold text-slate-700">Godzina (Od - Do)</label>
                                    <div class="flex items-center gap-2">
                                        <input 
                                            type="time" 
                                            data-model="startTime"
                                            value="{{ startTime|default('10:00') }}" 
                                            class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                        />
                                        <span class="text-slate-400">-</span>
                                        <input 
                                            type="time" 
                                            data-model="endTime"
                                            value="{{ endTime|default('11:30') }}" 
                                            class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                        />
                                    </div>
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-5 pt-2">
                                <div class="space-y-1.5">
                                    <label class="text-sm font-bold text-slate-700">Początek cyklu</label>
                                    <input 
                                        type="date" 
                                        data-model="startDate"
                                        class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                    />
                                </div>
                                <div class="space-y-1.5">
                                    <label class="text-sm font-bold text-slate-700">Zakończenie cyklu (opcjonalne)</label>
                                    <input 
                                        type="date" 
                                        data-model="endDate"
                                        class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none" 
                                    />
                                </div>
                            </div>

                            <div class="pt-2">
                                <label class="flex items-center gap-2 text-sm font-bold text-slate-700 cursor-pointer">
                                    <input 
                                        type="checkbox" 
                                        data-model="skipHolidays"
                                        class="w-4 h-4 rounded text-indigo-600" 
                                        checked
                                    />
                                    Omijaj dni ustawowo wolne od pracy (święta)
                                </label>
                            </div>
                        </div>
                    </div>
                {% endif %}

                <!-- TAB: TICKETS -->
                {% if activeTab == 'tickets' %}
                    <div class="space-y-6">
                        <div class="p-4 rounded-xl border-2 border-indigo-100 bg-indigo-50/50">
                            <h3 class="font-bold text-indigo-900 mb-2">Metody płatności</h3>
                            <label class="flex items-center gap-2 text-sm font-bold text-indigo-800 cursor-pointer">
                                <input 
                                    type="checkbox" 
                                    data-model="allowPayOnPlace"
                                    class="w-4 h-4 rounded text-indigo-600" 
                                />
                                Włącz opcję "Płatność na miejscu" (wymaga akceptacji przez prowadzącego/admina)
                            </label>
                            <p class="text-xs text-indigo-700 mt-1 ml-6">
                                Rezerwacje z tą opcją będą wymagały ręcznej akceptacji przed zajęciami.
                            </p>
                        </div>

                        <div class="space-y-4 border border-slate-200 p-5 rounded-xl">
                            <h3 class="font-bold text-slate-800 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                Cennik
                            </h3>
                            
                            <div class="space-y-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-32 text-sm font-bold text-slate-700">Jednorazowe</div>
                                    <div class="flex-1 flex items-center gap-2">
                                        <input 
                                            type="number" 
                                            data-model="singleTicketPrice"
                                            placeholder="55" 
                                            class="w-full p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none" 
                                        />
                                        <span class="text-sm text-slate-500">zł</span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3">
                                    <div class="w-32 text-sm font-bold text-slate-700">Karnet 4 wejścia</div>
                                    <div class="flex-1 flex items-center gap-2">
                                        <input 
                                            type="number" 
                                            data-model="carnet4Price"
                                            placeholder="200" 
                                            class="w-full p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none" 
                                        />
                                        <span class="text-sm text-slate-500">zł</span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3">
                                    <div class="w-32 text-sm font-bold text-slate-700">Karnet 8 wejść</div>
                                    <div class="flex-1 flex items-center gap-2">
                                        <input 
                                            type="number" 
                                            data-model="carnet8Price"
                                            placeholder="380" 
                                            class="w-full p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none" 
                                        />
                                        <span class="text-sm text-slate-500">zł</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}

                <!-- TAB: INSTRUCTORS -->
                {% if activeTab == 'instructors' %}
                    <div class="space-y-6">
                        <div class="space-y-4">
                            <div class="flex gap-2">
                                <select 
                                    data-model="newInstructorId"
                                    class="flex-1 p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
                                >
                                    <option value="">Wybierz prowadzącego...</option>
                                    {% for user in getUsers() %}
                                        {% if user.id not in instructorIds %}
                                            <option value="{{ user.id }}">{{ user.name }} ({{ user.email }})</option>
                                        {% endif %}
                                    {% endfor %}
                                </select>
                                <button 
                                    data-action="live#action" data-live-action-param="addInstructor"
                                    class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-bold hover:bg-indigo-700 transition"
                                >
                                    Dodaj
                                </button>
                            </div>
                            
                            {% for user in getInstructors() %}
                                <div class="flex justify-between items-center bg-slate-50 p-3 rounded-lg border border-slate-200">
                                    <div>
                                        <div class="font-bold text-sm text-slate-800">{{ user.name }}</div>
                                        <div class="text-xs text-slate-500">{{ user.email }}</div>
                                    </div>
                                    <button 
                                        data-action="live#action" data-live-action-param="removeInstructor" data-live-action-param-userId="{{ user.id }}"
                                        class="text-red-500 hover:bg-red-50 p-1.5 rounded-lg transition"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                    </button>
                                </div>
                            {% else %}
                                <div class="text-sm text-slate-500 text-center py-4 bg-slate-50 rounded-lg border border-slate-200">
                                    Brak przypisanych prowadzących
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>

            <!-- Footer -->
            <div class="p-6 border-t border-slate-100 bg-white flex justify-end gap-3 rounded-b-2xl">
                <button 
                    data-action="live#action" data-live-action-param="closeModal"
                    class="px-6 py-3 text-sm font-bold text-slate-600 hover:bg-slate-100 rounded-xl transition"
                >
                    Anuluj
                </button>
                <button 
                    data-action="live#action" data-live-action-param="save"
                    class="px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold rounded-xl shadow-md transition"
                >
                    Zapisz Szablon
                </button>
            </div>
        </div>
    </div>
</div>
{% endif %}
