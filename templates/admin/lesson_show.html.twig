{% extends 'admin/base.html.twig' %}
{% set activeTab = 'lessons' %}
{% set sub_breadcrumbs = [
    {'label': lesson.metadata.title},
    {'label': lesson.metadata.schedule|date('Y-m-d H:i')}
] %}

{% block title %}{{ 'admin.title'|trans }} — {{ lesson.metadata.title }}{% endblock %}

{% block topbar %}
    {{ include('admin/partials/topbar.html.twig', { activeTab: 'lessons', back_url: path('app_admin_lessons') }) }}
{% endblock %}

{% block body %}
    {# Breadcrumbs #}
    

    {# Header #}
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden">
        <div class="absolute left-0 top-0 bottom-0 w-2 bg-indigo-500"></div>
        <div class="pl-2">
            <h1 class="text-3xl font-black text-slate-800 flex items-center gap-3">
                {{ lesson.metadata.title }}
                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors {{ lesson.status == 'active' ? 'border-transparent bg-green-500 text-white' : 'border-transparent bg-red-500 text-white' }}">
                    {{ lesson.status == 'active' ? ('admin.lessons.status.active'|trans) : ('admin.lessons.status.cancelled'|trans) }}
                </span>
            </h1>
            <p class="text-slate-500 mt-1">
                {{ lesson.metadata.schedule|format_datetime('medium', 'short') }} · {{ 'lesson.minutes'|trans({'minutes': lesson.metadata.duration}) }} · {{ lesson.bookings|length }}/{{ lesson.metadata.capacity }}
            </p>
        </div>
        <div class="flex items-center gap-2">
            <form method="post" action="{{ path('app_admin_lesson_toggle', { id: lesson.id }) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle_lesson_' ~ lesson.id) }}">
                <button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-bold border h-10 rounded-xl px-4 transition-colors {{ lesson.status == 'active' ? 'border-red-600 text-red-600 hover:bg-red-50' : 'border-green-600 text-green-600 hover:bg-green-50' }}">
                    {{ lesson.status == 'active' ? ('admin.lessons.actions.deactivate'|trans) : ('admin.lessons.actions.activate'|trans) }}
                </button>
            </form>
            <a href="#" class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-bold border h-10 rounded-xl px-4 border-blue-600 text-blue-600 hover:bg-blue-50 transition-colors" aria-disabled="true">
                {{ 'Reschedule'|trans }}
            </a>
            <a href="#" class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-bold border h-10 rounded-xl px-4 border-slate-300 text-slate-700 hover:bg-slate-50 transition-colors" aria-disabled="true">
                {{ 'Modify'|trans }}
            </a>
            {% set emails = lesson.attendants|map(u => u.email)|join(',') %}
            <a href="mailto:?bcc={{ emails|url_encode }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-bold border h-10 rounded-xl px-4 border-amber-600 text-amber-700 hover:bg-amber-50 transition-colors">
                {{ 'Contact attendees'|trans }}
            </a>
        </div>
    </div>

    {# Prev/Next navigation in series #}
    {% if prevLesson or nextLesson %}
        <div class="flex items-center justify-between mb-6">
            <div>
                {% if prevLesson %}
                    <a class="text-sm font-semibold text-indigo-600 hover:underline flex items-center gap-1" href="{{ path('app_admin_lesson_view', { id: prevLesson.id }) }}">
                        ← {{ 'Previous lesson'|trans }} ({{ prevLesson.metadata.schedule|date('Y-m-d H:i') }})
                    </a>
                {% endif %}
            </div>
            <div>
                {% if nextLesson %}
                    <a class="text-sm font-semibold text-indigo-600 hover:underline flex items-center gap-1" href="{{ path('app_admin_lesson_view', { id: nextLesson.id }) }}">
                        {{ 'Next lesson'|trans }} ({{ nextLesson.metadata.schedule|date('Y-m-d H:i') }}) →
                    </a>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <section class="lg:col-span-2 rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="p-6 border-b border-slate-100 bg-slate-50">
                <h2 class="text-xl font-black text-slate-800">{{ 'Bookings'|trans }}</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm whitespace-nowrap">
                    <thead class="bg-slate-50 text-slate-500 border-b border-slate-100">
                        <tr>
                            <th class="px-6 py-4 font-semibold">{{ 'User'|trans }}</th>
                            <th class="px-6 py-4 font-semibold">{{ 'Status'|trans }}</th>
                            <th class="px-6 py-4 font-semibold">{{ 'Attendance'|trans }}</th>
                            <th class="px-6 py-4 font-semibold">{{ 'Notes'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        {% for booking in lesson.bookings %}
                            <tr class="hover:bg-slate-50/50 transition">
                                <td class="px-6 py-4">
                                    <div class="font-bold text-slate-800">{{ booking.user.name }}</div>
                                    <div class="text-xs text-slate-400 font-mono mt-0.5">{{ booking.user.email }}</div>
                                </td>
                                <td class="px-6 py-4">
                                    {% set status = booking.status %}
                                    <span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-bold transition-colors
                                        {{ status == 'confirmed' ? 'bg-green-100 text-green-700' : (status == 'cancelled' ? 'bg-red-100 text-red-700' : 'bg-slate-100 text-slate-600') }}">
                                        {{ status|trans }}
                                    </span>
                                    {% if booking.isLessonRescheduled(lesson) %}
                                        <span class="ml-2 text-xs font-bold text-amber-700 bg-amber-100 px-2 py-0.5 rounded">{{ 'Rescheduled'|trans }}</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-xs text-slate-400 font-medium">—</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-xs text-slate-600 font-medium">{{ booking.notes ?? '—' }}</span>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="px-6 py-8 text-center text-slate-400 font-medium">{{ 'No bookings yet'|trans }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <aside class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden h-fit">
            <div class="p-6 border-b border-slate-100 bg-slate-50">
                <h2 class="text-xl font-black text-slate-800">{{ 'Summary'|trans }}</h2>
            </div>
            <div class="p-6 space-y-4">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-semibold text-slate-500">{{ 'Capacity'|trans }}</span>
                    <span class="text-sm font-black text-slate-800">{{ lesson.metadata.capacity }}</span>
                </div>
                <div class="flex items-center justify-between border-t border-slate-100 pt-3">
                    <span class="text-sm font-semibold text-slate-500">{{ 'Booked'|trans }}</span>
                    <span class="text-sm font-black text-slate-800">{{ lesson.bookings|length }}</span>
                </div>
                <div class="flex items-center justify-between border-t border-slate-100 pt-3">
                    <span class="text-sm font-semibold text-slate-500">{{ 'Available'|trans }}</span>
                    <span class="text-sm font-black text-green-600">{{ lesson.getAvailableSpots() }}</span>
                </div>
            </div>
        </aside>
    </div>
{% endblock %}
