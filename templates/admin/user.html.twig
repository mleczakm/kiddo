{% extends 'admin/base.html.twig' %}
{% set activeTab = 'users' %}
{% set sub_breadcrumbs = [
    {'label': user.name}
] %}

{% block title %}{{ 'admin.title'|trans }} — {{ user.name }}{% endblock %}

{% block topbar %}
    {{ include('admin/partials/topbar.html.twig', { activeTab: 'users', back_url: path('app_admin_users') }) }}
{% endblock %}

{% block body %}
    

    {# KPI Row #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between space-y-0 pb-2">
                <h3 class="tracking-tight text-sm font-semibold text-slate-500">Total Spent</h3>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card text-slate-400 shrink-0"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
            </div>
            <div class="pt-2">
                <div class="text-2xl font-black text-slate-800">—</div>
                <p class="text-xs text-slate-400 font-medium mt-1">Across bookings</p>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between space-y-0 pb-2">
                <h3 class="tracking-tight text-sm font-semibold text-slate-500">Membership</h3>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity text-slate-400 shrink-0"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <div class="pt-2">
                <div class="text-2xl font-black text-slate-800">—</div>
                <p class="text-xs text-slate-400 font-medium mt-1">—</p>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between space-y-0 pb-2">
                <h3 class="tracking-tight text-sm font-semibold text-slate-500">Status</h3>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity text-green-500 shrink-0"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <div class="pt-2">
                <div class="text-2xl font-black text-slate-800">
                    <span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-bold bg-green-100 text-green-700">active</span>
                </div>
                <p class="text-xs text-slate-400 font-medium mt-1">Current account status</p>
            </div>
        </div>
    </div>

    {# Content Cards #}
    <div class="space-y-6">
        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="p-6 border-b border-slate-100 bg-slate-50">
                <h3 class="text-lg font-black text-slate-800">Personal Information</h3>
            </div>
            <div class="p-6 space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-wider">Full Name</label>
                        <p class="text-sm font-bold text-slate-800 mt-1">{{ user.name }}</p>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-wider">Email</label>
                        <p class="text-sm font-bold text-slate-800 mt-1">{{ user.email }}</p>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-wider">Phone</label>
                        <p class="text-sm font-bold text-slate-800 mt-1">{{ user.getPhone() ? '-' : '-' }}</p>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-wider">Registered</label>
                        <p class="text-sm font-bold text-slate-800 mt-1">{{ user.getCreatedAt() ? user.getCreatedAt()|date('Y-m-d H:i') ~ ' UTC' : '-' }}</p>
                    </div>
                    <div class="col-span-1 md:col-span-2">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-wider">Roles</label>
                        <p class="text-sm font-bold text-slate-800 mt-1">
                            {{ user.roles|map(role => '<span class="px-2 py-0.5 bg-slate-100 rounded text-xs text-slate-600 font-semibold">' ~ role ~ '</span>')|join(' ')|raw }}
                        </p>
                    </div>
                    <div class="col-span-1 md:col-span-2">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-wider">Notes</label>
                        <p class="text-sm text-slate-500 bg-slate-50 p-4 rounded-xl mt-1 border border-slate-100">—</p>
                    </div>
                </div>
            </div>
        </div>

        {# Children Profiles #}
        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="p-6 border-b border-slate-100 bg-slate-50">
                <h3 class="text-lg font-black text-slate-800">Children Profiles</h3>
            </div>
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {% for child in user.children %}
                        <div class="flex items-center gap-4 rounded-xl border border-slate-200 p-4 bg-slate-50/50">
                            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-indigo-100 text-indigo-700 font-black text-lg">
                                {{ child.name|first|upper }}
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-800">{{ child.name }}</h4>
                                <p class="text-xs text-slate-500 mt-0.5">
                                    {{ child.birthday ? child.birthday|date('Y-m-d') : 'Birthday unknown' }}
                                    · {{ child.getAgeYears() }} years old
                                </p>
                            </div>
                        </div>
                    {% else %}
                        <p class="text-slate-400 font-medium italic col-span-full">No children profiles registered.</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Recent Bookings #}
        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="p-6 border-b border-slate-100 bg-slate-50">
                <h3 class="text-lg font-black text-slate-800">Recent Bookings</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm whitespace-nowrap">
                    <thead class="bg-slate-50 text-slate-500 border-b border-slate-100">
                        <tr>
                            <th class="px-6 py-4 font-semibold">Workshop</th>
                            <th class="px-6 py-4 font-semibold">Date</th>
                            <th class="px-6 py-4 font-semibold">Status</th>
                            <th class="px-6 py-4 font-semibold text-right">Amount</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        {% for booking in user.bookings|slice(0, 10) %}
                            <tr class="hover:bg-slate-50/50 transition">
                                <td class="px-6 py-4 font-bold text-slate-800">{{ booking.lesson ? booking.lesson.metadata.title : '—' }}</td>
                                <td class="px-6 py-4 font-medium text-slate-600">{{ booking.createdAt|date('Y-m-d') }}</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-bold bg-slate-100 text-slate-600">{{ booking.status }}</span>
                                </td>
                                <td class="px-6 py-4 text-right font-bold text-slate-800">{{ booking.payment ? booking.payment.amount|money : '—' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="px-6 py-8 text-center text-slate-400 font-medium italic">No bookings found.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
