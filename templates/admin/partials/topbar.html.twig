<header class="bg-white h-16 border-b border-slate-200 flex items-center justify-between px-6 shrink-0 z-10 shadow-sm">
    <h1 class="font-bold text-lg text-slate-800 flex items-center gap-2">
        {% if back_url|default(null) %}
            <a href="{{ back_url }}" class="p-1.5 mr-2 bg-slate-100 rounded-lg hover:bg-slate-200 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left"><path d="m15 18-6-6 6-6"/></svg>
            </a>
        {% endif %}
        
        {% if app.request.attributes.get('_route') == 'app_admin_dashboard' %}
            {{ 'admin.title'|trans }}
        {% elseif app.request.attributes.get('_route') in ['app_admin_lessons', 'app_admin_lesson_view', 'app_admin_lesson_toggle'] %}
            {{ 'admin.tabs.lessons'|trans }}
        {% elseif app.request.attributes.get('_route') == 'app_admin_schedule' %}
            {{ 'admin.tabs.schedule'|trans }}
        {% elseif app.request.attributes.get('_route') == 'app_admin_transfers' %}
            {{ 'admin.tabs.transfers'|trans }}
        {% elseif app.request.attributes.get('_route') == 'app_admin_bookings' %}
            {{ 'admin.tabs.bookings'|trans }}
        {% elseif app.request.attributes.get('_route') in ['app_admin_users', 'app_admin_user_view'] %}
            {{ 'admin.tabs.users'|trans }}
        {% elseif app.request.attributes.get('_route') == 'app_admin_messages' %}
            {{ 'admin.tabs.messages'|trans }}
        {% elseif app.request.attributes.get('_route') == 'app_admin_settings' %}
            {{ 'admin.tabs.settings'|trans }}
        {% else %}
            {{ page_title|default('Kiddo Admin') }}
        {% endif %}
    </h1>
    
    <div class="flex items-center gap-4">
        {# Notification Bell #}
        <div class="relative">
            {{ component('NotificationTrayLiveComponent') }}
        </div>
        
        <div class="flex items-center gap-2 pl-4 border-l border-slate-200">
            <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-600 font-bold text-sm">
                {{ app.user ? app.user.email|slice(0, 1)|upper : 'A' }}
            </div>
            <span class="text-sm font-medium text-slate-700">
                {{ app.user ? app.user.email : 'Administrator' }}
            </span>
        </div>
    </div>
</header>
